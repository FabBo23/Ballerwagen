mqtt:
  # ==========================================
  # PLATFORM: BUTTON
  # ==========================================
  button:
    # --- BarBot Steuerung ---
    - name: "BarBot Start"
      unique_id: "barbot_cmd_start"
      command_topic: "barbot/cmd"
      payload_press: "start"
      icon: "mdi:play"
      device: &barbot_device
        identifiers: ["barbot_3000_device"]
        name: "BarBot 3000"
        model: "V4"
        manufacturer: "Eigenbau"
        configuration_url: "http://barbot.local"

    - name: "BarBot Stop"
      unique_id: "barbot_cmd_stop"
      command_topic: "barbot/cmd"
      payload_press: "stop"
      icon: "mdi:stop"
      device: *barbot_device

    # --- Ballerwagen Buttons ---
    - name: "STOP"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_stop"
      command_topic: "bollerwagen/cmd/speed"
      payload_press: "0"
      icon: "mdi:stop-circle-outline"
      device: &ballerwagen_device
        identifiers: ["01K9ZE5KM3EDYHYADPMWRPY2Z9"]
        manufacturer: "Ballerteam"
        model: "Ballerwagen"
        name: "Ballerwagen"

    - name: "Hupe"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_horn"
      command_topic: "bollerwagen/cmd/horn"
      payload_press: "1"
      icon: "mdi:bullhorn"
      device: *ballerwagen_device


  # ==========================================
  # PLATFORM: SENSOR
  # ==========================================
  sensor:
    - name: "BarBot Status"
      unique_id: "barbot_status"
      state_topic: "barbot/status"
      icon: "mdi:robot-industrial"
      device: *barbot_device

    # --- Ballerwagen Sensoren ---
    - name: "Geschwindigkeit"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_speed"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.speed }}"
      unit_of_measurement: "km/h"
      device_class: "speed"
      state_class: "measurement"
      device: *ballerwagen_device

    - name: "Drehzahl Sollwert"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_rpm_soll"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.rpm_soll }}"
      unit_of_measurement: "%"
      icon: "mdi:speedometer"
      device: *ballerwagen_device

    - name: "Drehzahl Istwert"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_rpm_ist"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.rpm_ist }}"
      unit_of_measurement: "%"
      icon: "mdi:speedometer-medium"
      device: *ballerwagen_device

    - name: "Temperatur"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_temp"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.temperature }}"
      unit_of_measurement: "°C"
      device_class: "temperature"
      state_class: "measurement"
      device: *ballerwagen_device

    - name: "Batterie SoC"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_soc"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.soc }}"
      unit_of_measurement: "%"
      device_class: "battery"
      state_class: "measurement"
      device: *ballerwagen_device

    - name: "Batteriespannung"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_voltage"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.voltage }}"
      unit_of_measurement: "V"
      device_class: "voltage"
      state_class: "measurement"
      device: *ballerwagen_device

    - name: "Strom"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_current"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.current }}"
      unit_of_measurement: "A"
      device_class: "current"
      state_class: "measurement"
      device: *ballerwagen_device

    - name: "Leistung"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_power"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.power }}"
      unit_of_measurement: "W"
      device_class: "power"
      state_class: "measurement"
      device: *ballerwagen_device

    - name: "Verbrauchte Energie"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_energy"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.energy_wh }}"
      unit_of_measurement: "Wh"
      device_class: "energy"
      state_class: "total_increasing"
      device: *ballerwagen_device

    # --- openHASP CYD Display Sensoren ---
    # Stellt den openHASP-Standard-Nodenamen "plate01" voraus.
    # Falls der Display-Nodename anders ist, überall "plate01" anpassen.
    - name: "Display Aktive Seite"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_display_page"
      state_topic: "hasp/plate01/state/page"
      icon: "mdi:page-layout-body"
      device: &ballerwagen_display
        identifiers: ["01K9ZE5KM3EDYHYADPMWRPY2Z9_display"]
        manufacturer: "Sunton"
        model: "CYD 2.4 (openHASP)"
        name: "Ballerwagen Display"
        via_device: "01K9ZE5KM3EDYHYADPMWRPY2Z9"

    - name: "Display IP"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_display_ip"
      state_topic: "hasp/plate01/state/statusupdate"
      value_template: "{{ value_json.ip }}"
      icon: "mdi:ip-network"
      entity_category: "diagnostic"
      device: *ballerwagen_display

    - name: "Display WLAN-Signal"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_display_rssi"
      state_topic: "hasp/plate01/state/statusupdate"
      value_template: "{{ value_json.rssi }}"
      unit_of_measurement: "dBm"
      device_class: "signal_strength"
      state_class: "measurement"
      entity_category: "diagnostic"
      device: *ballerwagen_display

    - name: "Display Uptime"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_display_uptime"
      state_topic: "hasp/plate01/state/statusupdate"
      value_template: "{{ value_json.uptime }}"
      unit_of_measurement: "s"
      device_class: "duration"
      entity_category: "diagnostic"
      device: *ballerwagen_display

    - name: "Display Freier Speicher"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_display_heap"
      state_topic: "hasp/plate01/state/statusupdate"
      value_template: "{{ value_json.heap }}"
      unit_of_measurement: "B"
      icon: "mdi:memory"
      entity_category: "diagnostic"
      device: *ballerwagen_display

    - name: "Display Letzter Button"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_display_last_object"
      state_topic: "hasp/plate01/state/statusupdate"
      value_template: "{{ value_json.lastObject }}"
      icon: "mdi:gesture-tap-button"
      entity_category: "diagnostic"
      device: *ballerwagen_display


  # ==========================================
  # PLATFORM: BINARY_SENSOR
