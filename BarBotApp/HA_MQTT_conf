    - name: "BarBot Glas 12"
      unique_id: "barbot_glass_11"
      state_topic: "barbot/glass/11"
      icon: "mdi:glass-cocktail"
      device: *barbot_device

    # --- Ballerwagen Binary Sensoren ---
    - name: "Totmannschalter"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_deadman"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.deadman }}"
      payload_on: "True"
      payload_off: "False"
      device_class: "safety"
      device: *ballerwagen_device

    # --- Display Online-Status (openHASP Last Will) ---
    - name: "Display Online"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_display_lwt"
      state_topic: "hasp/plate01/LWT"
      payload_on: "online"
      payload_off: "offline"
      device_class: "connectivity"
      entity_category: "diagnostic"
      device: *ballerwagen_display


  # ==========================================
  # PLATFORM: SWITCH
  # ==========================================
  switch:
    # --- Ballerwagen ---
    - name: "Rückwärtsgang"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_direction"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.direction }}"
      command_topic: "bollerwagen/cmd/direction"
      state_on: "R"
      state_off: "F"
      payload_on: "R"
      payload_off: "F"
      icon: "mdi:car-shift-pattern"
      device: *ballerwagen_device


  # ==========================================
  # PLATFORM: NUMBER
  # ==========================================
  number:
    # --- Ballerwagen ---
    - name: "Sollwert Geschwindigkeit"
      unique_id: "01K9ZE5KM3EDYHYADPMWRPY2Z9_speed_setpoint"
      state_topic: "bollerwagen/state"
      value_template: "{{ value_json.rpm_soll }}"
      command_topic: "bollerwagen/cmd/speed"
      min: 0
      max: 100
      step: 1
      mode: slider
      icon: "mdi:gauge"
      device: *ballerwagen_device


  # ==========================================
